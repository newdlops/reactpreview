{
  "name": "react-file-preview",
  "displayName": "React File Preview",
  "description": "Preview the active React component in an isolated VS Code webview without a web server.",
  "version": "0.1.1001",
  "publisher": "newdlops",
  "author": {
    "name": "newdlops",
    "url": "https://github.com/newdlops"
  },
  "license": "SEE LICENSE IN LICENSE",
  "homepage": "https://github.com/newdlops/reactpreview#readme",
  "bugs": {
    "url": "https://github.com/newdlops/reactpreview/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/newdlops/reactpreview.git"
  },
  "icon": "assets/icon.png",
  "galleryBanner": {
    "color": "#12182F",
    "theme": "dark"
  },
  "preview": true,
  "pricing": "Free",
  "engines": {
    "vscode": "^1.96.0"
  },
  "extensionKind": [
    "workspace"
  ],
  "categories": [
    "Other",
    "Visualization"
  ],
  "keywords": [
    "react",
    "preview",
    "component",
    "tsx",
    "jsx",
    "webview"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onCommand:reactPreview.open",
    "onCommand:reactPreview.refresh"
  ],
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": false,
      "description": "React File Preview bundles and executes code from the current workspace."
    },
    "virtualWorkspaces": {
      "supported": false
    }
  },
  "contributes": {
    "commands": [
      {
        "command": "reactPreview.open",
        "title": "Open Current React File",
        "category": "React Preview"
      },
      {
        "command": "reactPreview.refresh",
        "title": "Refresh",
        "category": "React Preview"
      }
    ],
    "configuration": {
      "title": "React Preview",
      "properties": {
        "reactPreview.updateDelay": {
          "type": "number",
          "default": 300,
          "minimum": 100,
          "maximum": 2000,
          "description": "Milliseconds to wait after an editor change before rebuilding the preview."
        },
        "reactPreview.tsconfig": {
          "type": "string",
          "default": "",
          "scope": "resource",
          "description": "Optional workspace-relative tsconfig or jsconfig path used for non-standard module aliases. Leave empty for esbuild's nearest-config discovery."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build:production",
    "build": "node ./scripts/build.mjs",
    "build:production": "npm run typecheck && node ./scripts/build.mjs --production",
    "build:watch": "node ./scripts/build.mjs --watch",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "typecheck:watch": "tsc --noEmit -p tsconfig.json --watch --preserveWatchOutput",
    "watch": "concurrently -k -n types,bundle \"npm:typecheck:watch\" \"npm:build:watch\"",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "check:lines": "node ./scripts/check-file-length.mjs",
    "check": "npm run check:lines && npm run typecheck && npm run lint && npm run format:check && npm test && npm run build",
    "package:vsix": "npm run check && node ./scripts/package-vsix.mjs"
  },
  "dependencies": {
    "esbuild": "0.28.1"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "20.19.43",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/vscode": "1.96.0",
    "@vscode/vsce": "3.9.2",
    "concurrently": "10.0.3",
    "eslint": "10.7.0",
    "eslint-plugin-jsdoc": "63.0.13",
    "globals": "17.7.0",
    "prettier": "3.9.5",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "typescript": "6.0.3",
    "typescript-eslint": "8.64.0",
    "vitest": "4.1.10"
  },
  "packageManager": "npm@10.9.7"
}
